# Copy to .env and fill in. Loaded automatically by bin/mathpix-mcp (via dotenv).
MATHPIX_APP_ID=your_app_id
MATHPIX_APP_KEY=your_app_key

# Optional
MATHPIX_MAX_FILE_SIZE_MB=10
MATHPIX_HTTPS_ONLY=true
# Where OCR results are written when a tool isn't given an explicit output path
# (defaults to the system temp dir).
# MATHPIX_OUTPUT_DIR=/path/to/output
# MATHPIX_API_URL=https://api.mathpix.com/v3
# MATHPIX_TIMEOUT=30
# MATHPIX_LOG_LEVEL=INFO   # DEBUG/INFO/WARN/ERROR — logs to stderr

# HTTP transport (bin/mathpix-mcp-http) — bearer token is REQUIRED in HTTP mode
MATHPIX_MCP_TOKEN=choose-a-long-random-secret
MATHPIX_MCP_HOST=127.0.0.1
MATHPIX_MCP_PORT=3000
